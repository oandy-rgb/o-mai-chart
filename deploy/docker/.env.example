# 複製成 .env 後填入實際值:cp .env.example .env
# .env 已被 .gitignore 忽略,切勿提交。

# --- Postgres ---
# docker 版新建的資料庫密碼(自訂一組強密碼)
POSTGRES_PASSWORD=

# --- 後端 ---
# production 必填。注意:更換此值會使既有使用者的登入 token 失效 → 需重新以 Google 登入。
JWT_SECRET=

# 好友碼雜湊 pepper。k3s 版實際使用的是預設值 dev-friend-code-pepper。
# 若要讓搬遷過來的好友身分能對應到「日後新提交的好友碼」,請保留此預設值;
# 改成別的值不影響已搬遷的資料,只會讓新提交無法對應到舊 identity。
FRIEND_CODE_PEPPER=dev-friend-code-pepper

# 管理員 email(逗號分隔),用於歌曲別名審核等 admin API
ADMIN_EMAILS=

# 允許的前端來源(CORS)
FRONTEND_ORIGIN=https://mai.o-andy.com

# --- Cloudflare Tunnel ---
# 沿用 k3s 既有 tunnel 的 token(見 runbook 如何從叢集取出),
# 這樣 public hostname 路由不需在 Cloudflare 端更動。
TUNNEL_TOKEN=

# --- 推薦模型訓練 ---
RECOMMEND_FACTORS=5
RECOMMEND_EPOCHS=36

# --- 備份到 Cloudflare R2(選用,啟用 backup profile 時需填)---
# 可沿用 k3s 時期的 R2 bucket 與憑證。endpoint 形如 https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=maimai-postgres-backup
R2_PREFIX=docker-dumps
BACKUP_KEEP_DAYS=30
BACKUP_INTERVAL=86400
